{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "node.boundingVolume.schema.json",
    "title": "glTF Node Bounding Volume",
    "type": "object",
    "description": "",
    "allOf": [ { "$ref": "glTFProperty.schema.json" } ],
    "properties": {
        "rotation": {
            "type": "array",
            "description": "The bounding volume's unit quaternion rotation in the order (X, Y, Z, W), where W is the scalar, relative to the node's local coordinate system.",
            "items": {
                "type": "number",
                "minimum": -1.0,
                "maximum": 1.0
            },
            "minItems": 4,
            "maxItems": 4,
            "default": [0.0, 0.0, 0.0, 1.0]
        },
        "scale": {
            "type": "array",
            "description": "The bounding volume's non-uniform scale, given as the scaling factors along the bounding volume's local X, Y, and Z axes.",
            "items": {
                "type": "number"
            },
            "minItems": 3,
            "maxItems": 3,
            "default": [1.0, 1.0, 1.0]
        },
        "shape": {
            "allOf": [ { "$ref": "glTFid.schema.json" } ],
            "description": "The index of the shape in the top-level `shapes` array. Required."
        },
        "translation": {
            "type": "array",
            "description": "The bounding volume's translation along the node's local X, Y, and Z axes.",
            "items": {
                "type": "number"
            },
            "minItems": 3,
            "maxItems": 3,
            "default": [0.0, 0.0, 0.0]
        }
    },
    "required": ["shape"]
}
